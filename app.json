{
  "expo": {
    "name": "Chess",
    "slug": "learn and improve while they play",
    "version": "0.2",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0E1E37"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.frog1014.chess"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E1E37",
          "image": "./assets/logox128.png",
          "imageWidth": 128
        }
      ]
    ]
  }
}
